{
  "id": "star_trek_quotes",
  "name": "Star Trek Quotes",
  "version": "1.1.0",
  "description": "Display random Star Trek quotes from TNG, Voyager, and DS9",
  "author": "FiestaBoard Team",
  "repository": "https://github.com/Fiestaboard/fiestaboard-plugin--star-trek-quotes",
  "documentation": "README.md",
  "icon": "star",
  "category": "entertainment",
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enable Star Trek Quotes",
        "default": false
      },
      "ratio": {
        "type": "string",
        "title": "Series Ratio",
        "description": "Weight ratio for TNG:Voyager:DS9 (e.g., 3:5:9)",
        "default": "3:5:9",
        "pattern": "^\\d+:\\d+:\\d+$"
      }
    }
  },
  "env_vars": [
    {
      "name": "STAR_TREK_QUOTES_ENABLED",
      "required": false,
      "description": "Enable Star Trek quotes feature",
      "default": "false"
    },
    {
      "name": "STAR_TREK_QUOTES_RATIO",
      "required": false,
      "description": "Weight ratio for TNG:Voyager:DS9",
      "default": "3:5:9"
    }
  ],
  "variables": {
    "groups": {
      "quote_data": {
        "label": "Quote"
      },
      "metadata": {
        "label": "Metadata"
      }
    },
    "simple": {
      "quote": {
        "description": "The Star Trek quote text",
        "type": "string",
        "max_length": 120,
        "group": "quote_data",
        "example": "Make it so."
      },
      "character": {
        "description": "Character who said the quote",
        "type": "string",
        "max_length": 15,
        "group": "quote_data",
        "example": "Picard"
      },
      "series": {
        "description": "Series abbreviation (tng, voyager, ds9)",
        "type": "string",
        "max_length": 7,
        "group": "metadata",
        "example": "tng"
      },
      "series_color": {
        "description": "Color code for the series",
        "type": "string",
        "max_length": 4,
        "group": "metadata",
        "example": "{67}"
      }
    }
  },
  "color_rules_schema": {
    "series": {
      "type": "match",
      "description": "Color based on Star Trek series",
      "default_rules": [
        {
          "condition": "==",
          "value": "tng",
          "color": "blue"
        },
        {
          "condition": "==",
          "value": "voyager",
          "color": "orange"
        },
        {
          "condition": "==",
          "value": "ds9",
          "color": "violet"
        }
      ]
    }
  },
  "fiestaboard_version": ">=2.10.0",
  "screenshots": [
    {
      "src": "docs/board-display.png",
      "alt": "Star Trek Quotes displayed on a Vestaboard",
      "caption": "Display random Star Trek quotes from TNG, Voyager, and DS9",
      "primary": true
    }
  ],
  "demo": {
    "name": "Star Trek Quotes Demo",
    "device_type": "flagship",
    "template": [
      "",
      "{{star_trek_quotes.quote}}",
      "",
      "",
      "{{star_trek_quotes.character}}",
      "{{star_trek_quotes.series}} {{star_trek_quotes.series_color}}"
    ],
    "line_metadata": [
      {
        "alignment": "center",
        "wrap": false
      },
      {
        "alignment": "center",
        "wrap": true
      },
      {
        "alignment": "center",
        "wrap": false
      },
      {
        "alignment": "center",
        "wrap": false
      },
      {
        "alignment": "right",
        "wrap": false
      },
      {
        "alignment": "right",
        "wrap": false
      }
    ]
  }
}
